# ─── Razorpay Configuration (PRODUCTION REQUIRED) ──────────────────────────────
# Get these from https://dashboard.razorpay.com/app/keys
#
# RAZORPAY_KEY_ID      - Server-side Razorpay API key (used by backend)
# RAZORPAY_KEY_SECRET   - Server-side Razorpay API secret (used by backend)
# NEXT_PUBLIC_RAZORPAY_KEY_ID - Client-side Razorpay key (exposed to browser for checkout.js)
#
# If left empty, the app runs in DEMO payment mode:
#   - Payments auto-succeed without opening the Razorpay modal
#   - All payment IDs are prefixed with "demo_" for identification
#   - This is suitable for development/testing but NOT for production
#
# For production deployment, set all three values with your Razorpay credentials.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
